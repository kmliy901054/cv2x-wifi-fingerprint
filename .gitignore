# Lab 3 — model checkpoints. Ignore all 90 (239 MB), but keep the 5-seed
# winning model (Cascade 2-level, ~18 MB) so the best result is reproducible.
lab3/outputs/checkpoints/*
!lab3/outputs/checkpoints/A_random__Cascade_s4[2-6].pt
!lab3/outputs/checkpoints/A_random__CascadeTuned_s4[2-6].pt
!lab3/outputs/checkpoints/A_random__CascadeAggressive_s4[2-6].pt

